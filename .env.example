# SmartPayBot — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o .env — ele contém segredos.

# ── Flask ──────────────────────────────────────────────────────────────
FLASK_ENV=development
# [OBRIGATÓRIO em produção] Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_UM_TOKEN_HEX_32_ALEATORIO

# ── Banco de dados ─────────────────────────────────────────────────────
# Dev (SQLite local):
DATABASE_URL=sqlite:///app.db
# Prod (PostgreSQL):
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/smartpaybot

# ── Telegram ───────────────────────────────────────────────────────────
# Token do bot obtido via @BotFather
TELEGRAM_TOKEN=SEU_TOKEN_AQUI
# Username do bot (sem @), usado para gerar deep links
TELEGRAM_BOT_USERNAME=nome_do_seu_bot
# [OBRIGATÓRIO em produção] Secret para autenticar o webhook.
# O Telegram envia este valor no header X-Telegram-Bot-Api-Secret-Token.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Deixe em branco em dev (polling local não usa este header).
TELEGRAM_WEBHOOK_SECRET=

# ── Scheduler (pipeline interno) ───────────────────────────────────────
# 0 = pipeline desligado na inicialização; 1 = liga automaticamente
SCHEDULER=0

# ── Painel de webhook (debug) ──────────────────────────────────────────
# 0 = oculto; 1 = visível no dashboard (apenas dev)
SHOW_WEBHOOK_PANEL=0

# ── Fuso horário ───────────────────────────────────────────────────────
TZ_NAME=America/Sao_Paulo

# ── Logs ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Varredura (opcional) ───────────────────────────────────────────────
SCAN_PAGES=10
SCAN_MIN_SECONDS=60
SCAN_MAX_SECONDS=180
MATCH_LOOKBACK_MINUTES=180

# ── Requisições HTTP (opcional) ────────────────────────────────────────
REQUEST_TIMEOUT=20

# ── Coletor local → VPS (arquitetura split) ─────────────────────────────
# [OBRIGATÓRIO em produção] Token compartilhado entre o coletor local e o endpoint da VPS.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Configure o mesmo valor no .env local e no .env da VPS.
INTERNAL_INGEST_TOKEN=
# URL do endpoint de ingestão na VPS (usado apenas no script local).
SMARTPAYBOT_INGEST_URL=https://smartpaybot.com.br/internal/ingest/projects
